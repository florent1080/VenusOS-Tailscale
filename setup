#!/bin/bash

# VenusOS-Tailscale setup script
# Installs Tailscale VPN on Venus OS (RPi3 ARMv7 / RPi5 ARM64)
#
# This script installs/uninstalls:
#   - Tailscale static binaries (downloaded at install time)
#   - tailscale.conf (default config, preserved on uninstall)
#   - tailscaled runit service (via SetupHelper INSTALL_SERVICES)

packageDir="$(dirname "$(realpath "$0")")"
INSTALL_DIR="/data/tailscale"
BIN_DIR="$INSTALL_DIR/bin"
STATE_DIR="$INSTALL_DIR/state"
CONF_SRC="$packageDir/tailscale.conf"
CONF_DST="$INSTALL_DIR/tailscale.conf"

#### following line incorporates helper resources into this script
source "/data/SetupHelper/HelperResources/IncludeHelpers"
#### end of lines to include helper resources

# Disable exit-on-error — SetupHelper may set it, we handle errors manually
set +e

#### running manually and target just install or uninstall
if [ $scriptAction == 'NONE' ] ; then
    echo
    echo "This package installs Tailscale VPN on Venus OS"
    echo "Edit /data/tailscale/tailscale.conf to set your AUTHKEY before installing"
    echo
    scriptAction=$(promptForAction)
fi

# ─── helpers ────────────────────────────────────────────────────────────────

detect_arch() {
    local machine
    machine="$(uname -m)"
    case "$machine" in
        armv7*|armv6*) echo "arm" ;;
        aarch64)       echo "arm64" ;;
        *)             echo "arm" ;;
    esac
}

get_tailscale_version() {
    # Try to get latest version using grep/awk (no python3 dependency)
    local version
    version=$(curl -sf --max-time 10 "https://pkgs.tailscale.com/stable/?mode=json" \
        | grep -o '"Version":"[^"]*"' | head -1 | cut -d'"' -f4 | tr -d 'v') 2>/dev/null || true
    if [ -z "$version" ]; then
        # Known good fallback version
        version="1.78.3"
        logMessage "version detection failed, using fallback $version"
    else
        logMessage "detected Tailscale version: $version"
    fi
    echo "$version"
}

download_tailscale() {
    local arch="$1"
    local tmpdir="/tmp/tailscale_install"
    rm -rf "$tmpdir"
    mkdir -p "$tmpdir"

    local version
    version=$(get_tailscale_version)

    local tarball="tailscale_${version}_${arch}.tgz"
    local url="https://pkgs.tailscale.com/stable/${tarball}"

    logMessage "downloading Tailscale $version for $arch ..."
    logMessage "URL: $url"
    curl -fL --max-time 120 "$url" -o "$tmpdir/$tarball"
    local curl_rc=$?
    if [ $curl_rc -ne 0 ]; then
        logMessage "ERROR: curl failed (rc=$curl_rc) for $url"
        return 1
    fi

    logMessage "extracting binaries..."
    tar xzf "$tmpdir/$tarball" -C "$tmpdir"
    local tar_rc=$?
    if [ $tar_rc -ne 0 ]; then
        logMessage "ERROR: tar extraction failed (rc=$tar_rc)"
        return 1
    fi

    # Find extracted directory (tailscale_VERSION_ARCH/)
    local extracted_dir
    extracted_dir=$(ls -d "$tmpdir"/tailscale_*/ 2>/dev/null | head -1)
    if [ -z "$extracted_dir" ] || [ ! -d "$extracted_dir" ]; then
        logMessage "ERROR: could not find extracted directory in $tmpdir"
        ls -la "$tmpdir" | while read line; do logMessage "  $line"; done
        return 1
    fi

    mkdir -p "$BIN_DIR"
    cp "$extracted_dir/tailscale"  "$BIN_DIR/tailscale"
    cp "$extracted_dir/tailscaled" "$BIN_DIR/tailscaled"
    chmod +x "$BIN_DIR/tailscale" "$BIN_DIR/tailscaled"

    rm -rf "$tmpdir"
    logMessage "Tailscale binaries installed to $BIN_DIR"
    return 0
}

# ─── INSTALL ─────────────────────────────────────────────────────────────────

if [ $scriptAction == 'INSTALL' ] ; then
    logMessage "installing VenusOS-Tailscale"

    mkdir -p "$BIN_DIR" "$STATE_DIR"

    if [ ! -x "$BIN_DIR/tailscaled" ]; then
        arch=$(detect_arch)
        logMessage "architecture: $arch"
        download_tailscale "$arch"
        dl_rc=$?
        if [ $dl_rc -ne 0 ]; then
            logMessage "ERROR: Tailscale download failed (rc=$dl_rc) — install incomplete"
            # Do not exit 1 — let SetupHelper continue, service won't start without binary
        fi
    else
        logMessage "Tailscale binaries already present, skipping download"
    fi

    # Install config (preserve existing)
    if [ ! -f "$CONF_DST" ]; then
        cp "$CONF_SRC" "$CONF_DST"
        logMessage "default config installed ($CONF_DST)"
    else
        logMessage "config already exists, preserved ($CONF_DST)"
    fi

    logMessage "Tailscale install complete"
fi

# ─── UNINSTALL ───────────────────────────────────────────────────────────────

if [ $scriptAction == 'UNINSTALL' ] ; then
    logMessage "uninstalling VenusOS-Tailscale"

    if [ -x "$BIN_DIR/tailscale" ]; then
        "$BIN_DIR/tailscale" logout 2>/dev/null || true
        logMessage "Tailscale logged out"
    fi

    rm -rf "$BIN_DIR"
    rm -rf "$STATE_DIR"
    logMessage "Tailscale binaries and state removed"
    logMessage "config preserved ($CONF_DST)"
fi

# SetupHelper handles runit service install/uninstall
endScript INSTALL_SERVICES

#### running manually and target just install or uninstall
if [ $scriptAction == 'NONE' ] ; then
    echo
    echo "This package installs Tailscale VPN on Venus OS"
    echo "Edit /data/tailscale/tailscale.conf to set your AUTHKEY before installing"
    echo
    scriptAction=$(promptForAction)
fi

# ─── helpers ────────────────────────────────────────────────────────────────

detect_arch() {
    local machine
    machine="$(uname -m)"
    case "$machine" in
        armv7*|armv6*) echo "arm" ;;
        aarch64)       echo "arm64" ;;
        *)             echo "arm" ;;  # safe fallback for RPi3
    esac
}

download_tailscale() {
    local arch="$1"
    local tmpdir="/tmp/tailscale_install"
    rm -rf "$tmpdir"
    mkdir -p "$tmpdir"

    # Get latest stable version number
    logMessage "detecting latest Tailscale stable version..."
    local version
    version=$(curl -sf "https://pkgs.tailscale.com/stable/?mode=json" \
        | python3 -c "import sys,json; d=json.load(sys.stdin); print(list(d['Tarballs'].values())[0]['Version'])" 2>/dev/null \
        | tr -d 'v')

    if [ -z "$version" ]; then
        # fallback hardcoded version
        version="1.80.3"
        logMessage "version detection failed, using fallback $version"
    else
        logMessage "latest Tailscale version: $version"
    fi

    local tarball="tailscale_${version}_${arch}.tgz"
    local url="https://pkgs.tailscale.com/stable/${tarball}"

    logMessage "downloading $url ..."
    if ! curl -fL "$url" -o "$tmpdir/$tarball"; then
        logMessage "ERROR: download failed from $url"
        return 1
    fi

    logMessage "extracting binaries..."
    tar xzf "$tmpdir/$tarball" -C "$tmpdir"

    local extracted_dir
    extracted_dir=$(find "$tmpdir" -maxdepth 1 -type d -name "tailscale_*" | head -1)
    if [ -z "$extracted_dir" ]; then
        logMessage "ERROR: could not find extracted directory"
        return 1
    fi

    mkdir -p "$BIN_DIR"
    cp "$extracted_dir/tailscale"  "$BIN_DIR/tailscale"
    cp "$extracted_dir/tailscaled" "$BIN_DIR/tailscaled"
    chmod +x "$BIN_DIR/tailscale" "$BIN_DIR/tailscaled"

    rm -rf "$tmpdir"
    logMessage "Tailscale binaries installed to $BIN_DIR"
    return 0
}

# ─── INSTALL ─────────────────────────────────────────────────────────────────

if [ $scriptAction == 'INSTALL' ] ; then
    logMessage "installing VenusOS-Tailscale"

    # Create directories
    mkdir -p "$BIN_DIR" "$STATE_DIR"

    # Download binaries if not already present (or outdated)
    if [ ! -x "$BIN_DIR/tailscaled" ]; then
        arch=$(detect_arch)
        logMessage "architecture: $arch"
        if ! download_tailscale "$arch"; then
            logMessage "ERROR: Tailscale download failed — aborting install"
            exit 1
        fi
    else
        logMessage "Tailscale binaries already present, skipping download"
    fi

    # Install config (preserve existing)
    if [ ! -f "$CONF_DST" ]; then
        cp "$CONF_SRC" "$CONF_DST"
        logMessage "default config installed ($CONF_DST)"
        logMessage "IMPORTANT: edit $CONF_DST and set AUTHKEY before use"
    else
        logMessage "config already exists, preserved ($CONF_DST)"
    fi

    # Make packageDir service script executable
    chmod +x "$packageDir/services/tailscaled/run" 2>/dev/null

    # Authenticate with Tailscale if AUTHKEY is set
    # (SetupHelper will start the service via INSTALL_SERVICES below)
    # We trigger auth after service is started via post-install note
    logMessage "Tailscale install complete"
    logMessage "Next steps:"
    logMessage "  1. Edit $CONF_DST — set AUTHKEY"
    logMessage "  2. Run: /data/VenusOS-Tailscale/tailscale_connect.sh"
    logMessage "     (or reboot — service will authenticate automatically)"

fi

# ─── UNINSTALL ───────────────────────────────────────────────────────────────

if [ $scriptAction == 'UNINSTALL' ] ; then
    logMessage "uninstalling VenusOS-Tailscale"

    # Disconnect from Tailscale network gracefully
    if [ -x "$BIN_DIR/tailscale" ]; then
        "$BIN_DIR/tailscale" logout 2>/dev/null || true
        logMessage "Tailscale logged out"
    fi

    # Remove binaries and state
    rm -rf "$BIN_DIR"
    rm -rf "$STATE_DIR"
    logMessage "Tailscale binaries and state removed"

    # Note: tailscale.conf is NOT removed (preserve user AUTHKEY)
    logMessage "config preserved ($CONF_DST)"
fi

# SetupHelper handles runit service install/uninstall
endScript INSTALL_SERVICES
